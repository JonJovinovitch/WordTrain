# Copy to `.env` for local dev. On Railway, set these as service Variables
# instead (Railway injects DATABASE_URL automatically once you add Postgres).

# Discord Developer Portal -> your app -> OAuth2
DISCORD_CLIENT_ID=your_application_id
DISCORD_CLIENT_SECRET=your_client_secret

# Same Application ID, exposed to the browser (public — this is fine).
VITE_DISCORD_CLIENT_ID=your_application_id

# Set automatically by Railway's Postgres plugin. Leave blank locally to use
# a throwaway JSON file instead of a real database.
# DATABASE_URL=postgresql://...
